---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Install Once - The Operating System for Life. A book by Gordon Ebanks." />
    <title>Install Once | The Operating System for Life</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col">
    <main class="flex-1 flex flex-col items-center justify-center px-6 py-12">
      <!-- Hero Section -->
      <div class="max-w-2xl mx-auto text-center">
        <!-- Logo/Title -->
        <h1 class="text-6xl md:text-8xl font-light tracking-tight text-cyan-glow glow-text mb-2">
          Install
        </h1>
        <h1 class="text-6xl md:text-8xl font-light tracking-tight text-cyan-glow glow-text mb-6">
          Once
        </h1>
        
        <!-- Tagline -->
        <p class="text-lg md:text-xl tracking-[0.3em] uppercase text-cyan-glow/70 mb-12">
          The Operating System for Life
        </p>
        
        <!-- Brain Icon - Lucide -->
        <div class="mb-12 animate-pulse-glow">
          <svg class="w-24 h-24 mx-auto text-cyan-glow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/>
            <path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/>
            <path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/>
            <path d="M12 18v4"/>
            <path d="M9 9h6"/>
          </svg>
        </div>
        
        <!-- Description -->
        <h2 class="text-2xl md:text-3xl font-semibold text-white mb-4 flex items-center justify-center gap-3">
          Turn Your Best Life Into Your New Reality.
          <svg class="w-8 h-8 text-cyan-glow inline-block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
            <path d="M21 3v5h-5"/>
            <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
            <path d="M8 16H3v5"/>
          </svg>
        </h2>
        
        <p class="text-gray-400 text-base md:text-lg mb-6 max-w-xl mx-auto leading-relaxed">
          What if you could install the identity, the behavior, and the default that actually work — once — and have them run in the background forever?
        </p>
        
        <p class="text-white text-base md:text-lg mb-6 max-w-xl mx-auto leading-relaxed font-medium">
          INSTALL ONCE flips the script.
        </p>
        
        <p class="text-gray-500 mb-8">
          The book drops soon. Join the waitlist and be the first to install.
        </p>
        
        <!-- Email Signup -->
        <div class="max-w-md mx-auto">
          <form id="signup-form" action="https://formspree.io/f/xreyqoab" method="POST" class="flex flex-col sm:flex-row gap-3 mb-3">
            <input 
              type="email" 
              name="email"
              placeholder="Enter your email" 
              required
              class="flex-1 px-5 py-3 bg-dark-surface border border-cyan-glow/30 rounded-lg 
                     text-white placeholder-gray-500 focus:outline-none focus:border-cyan-glow 
                     glow-border transition-all duration-300"
            />
            <button 
              type="submit"
              id="submit-btn"
              class="px-6 py-3 bg-cyan-glow text-dark-bg font-semibold rounded-lg 
                     hover:bg-cyan-glow/90 transition-all duration-300 
                     hover:shadow-[0_0_20px_rgba(0,240,255,0.5)]"
            >
              Notify Me
            </button>
          </form>
          <p id="form-status" class="text-gray-600 text-sm mt-4">
            Be the first to know when it launches. No spam, ever.
          </p>
        </div>
      </div>
    </main>
    
    <!-- Footer -->
    <footer class="py-6 text-center text-gray-600 text-sm">
      <p>&copy; 2025 Install Once. All rights reserved.</p>
    </footer>

    <script>
      const form = document.getElementById('signup-form');
      const button = document.getElementById('submit-btn');
      const status = document.getElementById('form-status');
      
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Show loading state
        button.textContent = 'Joining...';
        button.disabled = true;
        
        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { 'Accept': 'application/json' }
          });
          
          if (response.ok) {
            // Success
            button.textContent = "You're on the list!";
            button.classList.remove('bg-cyan-glow', 'hover:bg-cyan-glow/90');
            button.classList.add('bg-emerald-500');
            status.textContent = "🎉 Thanks! We'll notify you when the book drops.";
            status.classList.remove('text-gray-600');
            status.classList.add('text-emerald-400');
            form.reset();
          } else {
            throw new Error('Form submission failed');
          }
        } catch (error) {
          // Error
          button.textContent = 'Try Again';
          button.disabled = false;
          status.textContent = "Something went wrong. Please try again.";
          status.classList.remove('text-gray-600');
          status.classList.add('text-red-400');
        }
      });
    </script>
  </body>
</html>
